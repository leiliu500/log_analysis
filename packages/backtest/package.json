{
  "name": "@log/backtest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --test --import tsx ./src/*.test.ts",
    "backtest": "tsx src/cli.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@log/analysis": "*",
    "@log/app-apiflc": "*",
    "@log/app-scp": "*",
    "@log/applications": "*",
    "@log/shared": "*"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
