# Build from repo root:  docker build -f Dockerfile.web -t log-web .
FROM node:20-slim AS build
WORKDIR /app
COPY package.json package-lock.json* tsconfig*.json ./
COPY packages/shared ./packages/shared
COPY web ./web
RUN npm install --workspaces --include-workspace-root
# Next.js inlines NEXT_PUBLIC_* at build time, so the API base URL must be set here.
ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
RUN npm run build --workspace @log/shared && npm run build --workspace web

FROM node:20-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build /app/web/.next ./web/.next
COPY --from=build /app/web/public ./web/public
COPY --from=build /app/web/package.json ./web/package.json
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/packages/shared ./packages/shared
EXPOSE 3000
WORKDIR /app/web
CMD ["npx", "next", "start", "-p", "3000"]
