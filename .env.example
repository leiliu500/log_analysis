# ---------- AWS ----------
AWS_REGION=us-east-1
AWS_PROFILE=default
# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-5-20250101-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# Supervisor Bedrock Agent (created by Terraform, output: supervisor_agent_id)
BEDROCK_SUPERVISOR_AGENT_ID=
BEDROCK_SUPERVISOR_AGENT_ALIAS_ID=

# ---------- Postgres ----------
DATABASE_URL=postgres://loguser:logpass@localhost:5432/loganalysis
PGVECTOR_ENABLED=true

# ---------- Log sources ----------
# CloudWatch
CLOUDWATCH_LOG_GROUPS=/aws/lambda/my-app,/aws/ecs/my-service
# Splunk
SPLUNK_HOST=https://splunk.example.com:8089
SPLUNK_TOKEN=
# Grafana Loki
GRAFANA_LOKI_URL=https://loki.example.com
GRAFANA_API_TOKEN=
# Email alerts (IMAP or SES inbound bucket)
EMAIL_IMAP_HOST=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_S3_BUCKET=

# ---------- API / Web ----------
API_PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------- Real application routing (Supervisor -> app endpoints) ----------
# JSON map of appName -> endpoint, e.g. {"scp":"https://scp.internal/api"}
APP_ENDPOINTS_JSON={"scp":"https://scp.example.internal/api/execute"}
